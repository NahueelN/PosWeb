{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PosWeb",
  "version": "0.1.0",
  "identifier": "com.posweb.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PosWeb — Punto de Venta",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/posweb-backend"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnRzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFQjBGMUE2OUJFNEVEMzUKUldRMTdlU2Jwdkd3SGh0RmhVUnhhdC9lSEpQVFlTeU1paXhRWUIyME9Wb01IdGxZSDVaU1FoYkYK",
      "endpoints": [
        "https://raw.githubusercontent.com/NahueelN/PosWeb/main/latest.json"
      ]
    }
  }
}
